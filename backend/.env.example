NODE_ENV=development
HOST=0.0.0.0
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ondo_evoting

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-character-hex-key

# Comma-separated list in production, for example:
# CORS_ORIGIN=https://ondo-vote.example.com,https://admin.ondo-vote.example.com
CORS_ORIGIN=

FALLBACK_APPROVAL_CODE=replace-with-secure-officer-fallback-code
RESET_PASSWORD_BASE_URL=https://your-app.example.com/voter/reset-password

# Local default logs reset links to console until you choose an email provider.
EMAIL_PROVIDER=console
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=no-reply@ondo-evoting.example

# SMS is intentionally mocked for this project.
# Registration SMS payloads are logged as mock_registration_sms events.
